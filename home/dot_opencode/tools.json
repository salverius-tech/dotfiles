{
  "tools": [
    {
      "name": "maestro",
      "description": "Dry-run executor for planning and pipeline simulation",
      "handler": "external",
      "mode": "dry-run-only",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["plan"]
          },
          "pipeline": {
            "type": "string"
          }
        },
        "required": ["action", "pipeline"]
      }
    }
  ]
}
