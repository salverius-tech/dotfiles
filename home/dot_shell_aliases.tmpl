# Shared shell aliases (sourced by both bash and zsh)
# Managed by chezmoi
{{- $pm := "unknown" }}
{{- if hasKey . "package_manager" }}{{ $pm = .package_manager }}{{ end }}
{{- $isWsl := false }}
{{- if hasKey . "is_wsl" }}{{ $isWsl = .is_wsl }}{{ end }}

# Kubernetes
alias kc='kubectl'

# Pi coding agent
alias pic='pi -c'
alias pir='pi -r'
alias pin='pi --no-session'
alias pi-readonly='pi --tools read,grep,find,ls'

# File listing (cross-platform)
{{- if eq .chezmoi.os "darwin" }}
alias l='ls -lhaG'
{{- else }}
alias l='ls --color -lha --group-directories-first'
{{- end }}

# Development directory
{{- if eq .chezmoi.os "windows" }}
alias cddev='cd /c/dev'
{{- else }}
alias cddev='cd /devdata'
{{- end }}

# Network commands
{{- if eq .chezmoi.os "linux" }}
alias ipa='ip -br -c a'
alias ipn='ip -c n'
{{- else if eq .chezmoi.os "darwin" }}
alias ipa='ifconfig | grep inet'
alias ipn='arp -a'
{{- end }}

# System update (distro-agnostic)
{{- if eq $pm "apt" }}
alias update='sudo apt update && sudo apt upgrade -y'
{{- else if eq $pm "apk" }}
alias update='sudo apk update && sudo apk upgrade'
{{- else if eq $pm "dnf" }}
alias update='sudo dnf upgrade --refresh -y'
{{- else if eq $pm "pacman" }}
alias update='sudo pacman -Syu --noconfirm'
{{- else if eq $pm "zypper" }}
alias update='sudo zypper refresh && sudo zypper update -y'
{{- else if eq $pm "brew" }}
alias update='brew update && brew upgrade'
{{- else if eq $pm "nix" }}
alias update='nix-channel --update && nix-env -u'
{{- end }}

# Shutdown
{{- if ne .chezmoi.os "windows" }}
alias sdn='sudo shutdown -h now'
{{- end }}

# WSL-specific aliases
{{- if $isWsl }}
alias explorer='explorer.exe .'
alias clip='clip.exe'
alias open='wslview'
{{- end }}

# Docker aliases (loaded if docker is installed and file exists)
# Note: chezmoi ignores this file if docker is not found at install time,
# but we still check at runtime for robustness
if [ -f ~/.docker_aliases ]; then
    . ~/.docker_aliases
fi
